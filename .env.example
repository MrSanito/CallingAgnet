# ────────────────────────────────────────────────────────────────────────────
#  Rentopus — Environment Variables
#  Copy this file to .env and fill in your values
#  Run: cp .env.example .env
# ────────────────────────────────────────────────────────────────────────────

# Google Gemini AI API Key (for transcript parsing)
GOOGLE_API_KEY=your_google_api_key_here

# VideoSDK Credentials (for SIP calling)
VIDEOSDK_AUTH_TOKEN=your_videosdk_auth_token_here
VIDEOSDK_SIP_CALL_FROM=+1234567890
VIDEOSDK_ROUTING_RULE_ID=rr_xxxxxx

# MongoDB — Leave as-is for Docker, the compose file handles internal routing
# Only change this if you're using MongoDB Atlas or an external database
MONGODB_URI=mongodb://mongodb:27017/call_scheduler

# VideoSDK Webhook URL — Your public-facing domain for recording callbacks
VIDEOSDK_WEBHOOK_URL=https://your-domain.com/api/v1/webhooks/recording

# RCRM API Key
RCRM_API_KEY=your_rcrm_api_key_here
